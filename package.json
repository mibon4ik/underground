{
  "name": "underground-fitness-academy",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.4"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "node backend/prisma/seed.js"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "node backend/server.js",
    "build": "vite build",
    "start": "npx prisma migrate deploy --schema backend/prisma/schema.prisma && node backend/server.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "db:seed": "node backend/prisma/seed.js",
    "db:studio": "npx prisma studio --schema backend/prisma/schema.prisma"
  }
}
